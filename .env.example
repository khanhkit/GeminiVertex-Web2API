# ==============================================
# Gemini Web Cookies
# ==============================================
# Default account (no suffix)
__Secure-1PSID=
__Secure-1PSIDTS=

# Extra accounts (with custom suffix)
# __Secure-1PSID_main=
# __Secure-1PSIDTS_main=
# __Secure-1PSID_work=
# __Secure-1PSIDTS_work=

# ==============================================
# Load Balancing Configuration
# ==============================================
# Enabled account list, supports: [main,work] / {main,work} / main,work
# Leave empty to automatically use all configured accounts
ACCOUNTS=

# ==============================================
# HTTP Proxy Configuration (Optional)
# ==============================================
# Global proxy: Used by all accounts by default
# Supported formats: http://host:port / http://user:pass@host:port / socks5://host:port
PROXY=

# Independent proxy per account: Overrides global PROXY
# Examples: PROXY_main=socks5://127.0.0.1:7890
#           PROXY_work=http://192.168.1.1:8080
# PROXY_main=
# PROXY_work=

# ==============================================
# API Security Configuration
# ==============================================
PROXY_API_KEY=123

# ==============================================
# Service Port
# ==============================================
PORT=8007

# ==============================================
# Gemini Base URL (Optional)
# ==============================================
# Gemini Web UI Base URL, used for all API requests.
# Default: https://gemini.google.com
# Example: https://vertexaisearch.cloud.google.com
GEMINI_BASE_URL=

# ==============================================
# Language Configuration
# ==============================================
# Used for Accept-Language header and f.req payload language fields
# Default: en, options: zh-TW, zh-CN, ja, ko, etc.
LANGUAGE=en

# ==============================================
# Model Mapping (Claude/OpenAI model name -> Gemini model name)
# ==============================================
# Format: source1:target1,source2:target2
# Example: claude-haiku-4-5-20251001:gemini-3-flash-preview-no-thinking,claude-sonnet-4-5:gemini-3-flash-preview
MODEL_MAPPING=claude-haiku-4-5-20251001:gemini-3-flash-preview-no-thinking
